<Window x:Class="WpfApp4_Cvicenie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp4_Cvicenie"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="900">
    <Grid Margin="0,0,10,-6">
        <TextBox x:Name="NewStudentText" HorizontalAlignment="Left" Margin="142,50,0,0" TextWrapping="Wrap" Text="rado" VerticalAlignment="Top" Width="75" Height="43" RenderTransformOrigin="0.493,0.467"/>
        <Button x:Name="AddStudent" Content="Button" HorizontalAlignment="Left" Margin="288,50,0,0" VerticalAlignment="Top" Click="AddStudent_Click" Height="43" Width="63"/>
        <ListBox x:Name="Listofstudents" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,120,648,142" SelectionChanged="Listofstudents_SelectionChanged"/>
        <Button x:Name="Deletestudent" Content="Delete Student" HorizontalAlignment="Left" Margin="84,353,0,0" VerticalAlignment="Top" Click="Deletestudent_Click"/>
        <Label x:Name="StudentName" Content="Label" HorizontalAlignment="Left" Margin="320,144,0,0" VerticalAlignment="Top" Height="35" Width="125"/>
        <Label Content="Add a grade" HorizontalAlignment="Left" Margin="320,217,0,0" VerticalAlignment="Top" Height="27" Width="96"/>
        <ComboBox x:Name="GradeSelector" HorizontalAlignment="Left" Margin="416,217,0,0" VerticalAlignment="Top" Width="98" Height="28" RenderTransformOrigin="0.529,0.643">
            <Button Content="1" Cursor="Arrow"/>
            <Button Content="2"/>
            <Button Content="3"/>
            <Button Content="4"/>
            <Button Content="5"/>
        </ComboBox>
        <Button x:Name="AddGrade" Content="Button" HorizontalAlignment="Left" Margin="553,217,0,0" VerticalAlignment="Top" Height="28" Width="63" Click="AddGrade_Click"/>
        <ListBox x:Name="Grades" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="288,274,336,100"/>
        <Label x:Name="NumberOfGrades" Content="Number of grades" HorizontalAlignment="Left" Margin="269,421,0,0" VerticalAlignment="Top" Height="31" Width="108" RenderTransformOrigin="0.5,0.5">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.827"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label x:Name="AverageGrades" Content="Average grades" HorizontalAlignment="Left" Margin="500,421,0,0" VerticalAlignment="Top" Height="33" Width="102"/>
        <Label Content="0" HorizontalAlignment="Center" Margin="0,421,0,0" VerticalAlignment="Top" Width="58" Height="33"/>
        <Label Content="0" HorizontalAlignment="Left" Margin="607,421,0,0" VerticalAlignment="Top" Height="33" Width="66"/>

    </Grid>
</Window>
